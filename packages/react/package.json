{
  "name": "@kksh/react",
  "version": "0.1.1",
  "author": {
    "name": "Huakun",
    "url": "https://huakunshen.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HuakunTech/kunkun.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./css": {
      "types": "./src/style.css.d.ts",
      "default": "./dist/style.css"
    },
    "./themes": {
      "types": "./src/style.css.d.ts",
      "default": "./dist/themes.css"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && shx cp src/registry/themes.css ./dist/themes.css",
    "build:docs": "typedoc src/index.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
